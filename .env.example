# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values for local development.
# In production, set these in the Vercel dashboard (Project → Settings →
# Environment Variables). `.env.local` is git-ignored and must never be committed.
# ---------------------------------------------------------------------------

# YouTube Data API v3 key. SERVER-ONLY.
# This is read via process.env in the API route and NEVER sent to the browser.
# Do NOT prefix it with NEXT_PUBLIC_ — that would leak it into the client bundle.
YOUTUBE_API_KEY=

# Optional lightweight passcode gate.
# If set, the /api/comments route requires the client to supply a matching
# passcode (entered once in the app and kept in localStorage). This keeps a
# public Vercel URL from letting strangers burn your YouTube quota.
# Leave it unset/blank to disable the check entirely.
# Heavier alternative: Vercel Deployment Protection (Project → Settings).
APP_PASSCODE=
